package {{ENTITY}}

import (
	"encoding/json"
	"errors"
	"net/http"
	"strconv"

	platformhttp "{{SERVICE}}/internal/platform/http"
	"{{SERVICE}}/internal/platform/render"

	"keeper/pkg/auth"

	"github.com/go-chi/chi/v5"
	"github.com/go-playground/validator/v10"
)

type Handler struct {
	svc      Service
	validate *validator.Validate
}

func NewHandler(svc Service) *Handler {
	return &Handler{
		svc:      svc,
		validate: validator.New(),
	}
}

func (h *Handler) Routes() chi.Router {
	r := chi.NewRouter()
	r.Post("/", h.Create)
	r.Get("/", h.List)
	r.Route("/{id}", func(r chi.Router) {
		r.Get("/", h.GetByID)
		r.Put("/", h.Update)
		r.Delete("/", h.Delete)
	})
	return r
}

func (h *Handler) getClaims(r *http.Request) (*auth.UserClaims, error) {
	claims, ok := auth.GetClaimsFromContext(r.Context())
	if !ok {
		return nil, errors.New("user not authenticated")
	}
	return claims, nil
}

// Create handles {{ENTITY}} creation.
// @Summary Create a new {{ENTITY}}
// @Description Create a new {{ENTITY}}
// @Tags {{ENTITY_PLURAL}}
// @Accept json
// @Produce json
// @Param body body Create{{ENTITY_PASCAL}}Request true "{{ENTITY_PASCAL}} object"
// @Success 201 {object} render.Response{data={{ENTITY_PASCAL}}}
// @Failure 400 {object} render.Response
// @Failure 401 {object} render.Response
// @Failure 500 {object} render.Response
// @Security Bearer
// @Router /{{ENTITY_PLURAL}} [post]
func (h *Handler) Create(w http.ResponseWriter, r *http.Request) {
	claims, err := h.getClaims(r)
	if err != nil {
		render.Error(w, http.StatusUnauthorized, err.Error())
		return
	}

	var req Create{{ENTITY_PASCAL}}Request
	if err := json.NewDecoder(r.Body).Decode(&req); err != nil {
		render.Error(w, http.StatusBadRequest, "invalid request body")
		return
	}

	item, err := h.svc.Create(r.Context(), claims.AppID, claims.UserID, req)
	if err != nil {
		render.Error(w, http.StatusInternalServerError, err.Error())
		return
	}

	render.JSON(w, http.StatusCreated, item)
}

// List handles listing all {{ENTITY_PLURAL}}.
// @Summary List all {{ENTITY_PLURAL}}
// @Description Get a list of all {{ENTITY_PLURAL}} for the authenticated app
// @Tags {{ENTITY_PLURAL}}
// @Produce json
// @Param limit query int false "Max items to return (default 50, max 500)"
// @Param offset query int false "Items to skip (default 0)"
// @Success 200 {object} render.Response{data=[]{{ENTITY_PASCAL}}}
// @Failure 401 {object} render.Response
// @Failure 500 {object} render.Response
// @Security Bearer
// @Router /{{ENTITY_PLURAL}} [get]
func (h *Handler) List(w http.ResponseWriter, r *http.Request) {
	claims, err := h.getClaims(r)
	if err != nil {
		render.Error(w, http.StatusUnauthorized, err.Error())
		return
	}

	p := platformhttp.ParsePagination(r)
	items, err := h.svc.List(r.Context(), claims.AppID, claims.UserID, p.Limit, p.Offset)
	if err != nil {
		render.Error(w, http.StatusInternalServerError, err.Error())
		return
	}

	render.JSON(w, http.StatusOK, items)
}

// GetByID handles getting a {{ENTITY}} by ID.
// @Summary Get {{ENTITY}} by ID
// @Description Get a single {{ENTITY}} by its ID
// @Tags {{ENTITY_PLURAL}}
// @Produce json
// @Param id path int true "{{ENTITY_PASCAL}} ID"
// @Success 200 {object} render.Response{data={{ENTITY_PASCAL}}}
// @Failure 400 {object} render.Response
// @Failure 401 {object} render.Response
// @Failure 404 {object} render.Response
// @Failure 500 {object} render.Response
// @Security Bearer
// @Router /{{ENTITY_PLURAL}}/{id} [get]
func (h *Handler) GetByID(w http.ResponseWriter, r *http.Request) {
	claims, err := h.getClaims(r)
	if err != nil {
		render.Error(w, http.StatusUnauthorized, err.Error())
		return
	}

	id, err := h.getIDParam(r)
	if err != nil {
		render.Error(w, http.StatusBadRequest, "invalid {{ENTITY}} ID")
		return
	}

	item, err := h.svc.GetByID(r.Context(), claims.AppID, claims.UserID, id)
	if err != nil {
		if errors.Is(err, Err{{ENTITY_PASCAL}}NotFound) {
			render.Error(w, http.StatusNotFound, "{{ENTITY}} not found")
			return
		}
		render.Error(w, http.StatusInternalServerError, err.Error())
		return
	}

	render.JSON(w, http.StatusOK, item)
}

