ENVIRONMENT: production
SERVER:
  ADDR: ":{{SERVICE_PORT}}"
  HOST: "localhost:{{SERVICE_PORT}}"
  READ_TIMEOUT: 5s
  WRITE_TIMEOUT: 10s
  IDLE_TIMEOUT: 120s
DATABASE:
  PATH: "data/{{SERVICE}}.db"
  DRIVER: "sqlite3"
  DSN: ""
LOG:
  DIR: "log"
  LEVEL: "info"
AUTH:
  JWT_SECRET: "a-very-secure-and-shared-secret-key"
  JWT_EXPIRY: 24h
CORS:
  ALLOWED_ORIGINS:
    - "*"
# Optional secondary listeners: extra ports in the same process, each
# exposing only its allow-listed routes. Identity always comes from JWT;
# JWT_SECRET (optional) makes the listener verify with a different signing
# key (e.g. keeper's guest secret) instead of AUTH.JWT_SECRET.
# Per-entry defaults: RATE_LIMIT 100 req / 1m, NAME secondary-<i>.
SECONDARY: []
